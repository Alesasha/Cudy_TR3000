#!/bin/sh
set -eu

ROUTES_FILE="${ROUTES_FILE:-/etc/cudy-user-routes/routes.tsv}"
NFT_TABLE="${NFT_TABLE:-cudy_user_routes}"
NFT_FAMILY="${NFT_FAMILY:-inet}"
NFT_CHAIN="${NFT_CHAIN:-prerouting}"
WORK_DIR="/tmp/cudy-user-routes.$$"

cleanup() {
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT

mkdir -p "$WORK_DIR"

safe_name() {
  case "$1" in
    ''|*[!A-Za-z0-9_.-]*) return 1 ;;
    *) return 0 ;;
  esac
}

valid_ipv4() {
  printf '%s\n' "$1" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}$'
}

mark_for_iface() {
  iface="$1"
  ip rule show 2>/dev/null | awk -v table="pbr_$iface" '
    $0 ~ ("lookup " table "$") {
      for (i = 1; i <= NF; i++) {
        if ($i == "fwmark") {
          split($(i + 1), parts, "/")
          print parts[1]
          exit
        }
      }
    }
  '
}

resolve_domains() {
  domain_file="$1"
  while read -r domain; do
    [ -n "$domain" ] || continue
    nslookup "$domain" 2>/dev/null \
      | awk '/^Address[ 0-9]*: / { print $NF }' \
      | grep -E '^([0-9]{1,3}\.){3}[0-9]{1,3}$' \
      | awk '{ print $1 "/32" }' || true
  done < "$domain_file" | sort -u
}

append_nft_elements() {
  set_name="$1"
  ip_file="$2"
  batch="$3"
  [ -s "$ip_file" ] || return 1

  n=0
  params=""
  while read -r ip; do
    [ -n "$ip" ] || continue
    params="${params:+$params, }$ip"
    n=$((n + 1))
    if [ "$n" -ge 200 ]; then
      echo "add element $NFT_FAMILY $NFT_TABLE $set_name { $params }" >> "$batch"
      params=""
      n=0
    fi
  done < "$ip_file"
  [ -z "$params" ] || echo "add element $NFT_FAMILY $NFT_TABLE $set_name { $params }" >> "$batch"
}

if [ ! -f "$ROUTES_FILE" ]; then
  echo "Missing routes file: $ROUTES_FILE" >&2
  exit 1
fi

while IFS="$(printf '\t')" read -r group user_id client_ip iface domain; do
  case "$group" in ''|\#*) continue ;; esac
  safe_name "$group" || { echo "Unsafe group: $group" >&2; exit 1; }
  safe_name "$iface" || { echo "Unsafe interface: $iface" >&2; exit 1; }
  valid_ipv4 "$client_ip" || { echo "Invalid client IP: $client_ip" >&2; exit 1; }
  printf '%s\t%s\t%s\n' "$client_ip" "$iface" "$user_id" > "$WORK_DIR/$group.meta"
  printf '%s\n' "$domain" >> "$WORK_DIR/$group.domains"
done < "$ROUTES_FILE"

batch="$WORK_DIR/apply.nft"
{
  echo "add table $NFT_FAMILY $NFT_TABLE"
  echo "add chain $NFT_FAMILY $NFT_TABLE $NFT_CHAIN { type filter hook prerouting priority -149; policy accept; }"
} > "$batch"

groups=0
rules=0
for domain_file in "$WORK_DIR"/*.domains; do
  [ -e "$domain_file" ] || continue
  group="${domain_file##*/}"
  group="${group%.domains}"
  set_name="dst_$group"
  meta="$(cat "$WORK_DIR/$group.meta")"
  client_ip="$(printf '%s\n' "$meta" | awk -F '\t' '{print $1}')"
  iface="$(printf '%s\n' "$meta" | awk -F '\t' '{print $2}')"
  mark="$(mark_for_iface "$iface")"
  [ -n "$mark" ] || {
    echo "No PBR fwmark found for interface: $iface" >&2
    exit 1
  }

  ip_file="$WORK_DIR/$group.ips"
  resolve_domains "$domain_file" > "$ip_file"
  if [ ! -s "$ip_file" ]; then
    echo "WARN: no IPv4 resolved for group=$group iface=$iface client=$client_ip" >&2
    continue
  fi

  echo "add set $NFT_FAMILY $NFT_TABLE $set_name { type ipv4_addr; flags interval; auto-merge; }" >> "$batch"
  append_nft_elements "$set_name" "$ip_file" "$batch"
  echo "add rule $NFT_FAMILY $NFT_TABLE $NFT_CHAIN ip saddr $client_ip ip daddr @$set_name meta mark set $mark comment \"cudy-user-routes $group $iface\"" >> "$batch"
  groups=$((groups + 1))
  rules=$((rules + 1))
done

nft delete table "$NFT_FAMILY" "$NFT_TABLE" 2>/dev/null || true
nft -f "$batch"

if command -v conntrack >/dev/null 2>&1; then
  awk -F '\t' 'NF >= 3 && $1 !~ /^#/ { print $3 }' "$ROUTES_FILE" | sort -u | while read -r client_ip; do
    conntrack -D -s "$client_ip" >/dev/null 2>&1 || true
  done
fi

echo "Applied Cudy user routes: groups=$groups rules=$rules"
