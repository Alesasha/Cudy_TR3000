#!/bin/sh
set -eu

CONFIG="${CONFIG:-/etc/sing-box/vpntype.json}"
SERVICE="${SERVICE:-/etc/init.d/sing-box-vpntype}"
TAG_MAP="${TAG_MAP:-/root/vpn-subscriptions/vpntype.tags.txt}"
AUTO_TAG='vpntype-auto'
PROXY_QUIC_TAG='proxy-kz'
PROXY_QUIC_TABLE='inet fw4'
PROXY_QUIC_CHAIN='forward'

usage() {
  cat >&2 <<'EOF'
Usage:
  vpntype-server list
  vpntype-server status
  vpntype-server auto
  vpntype-server use TAG

Examples:
  vpntype-server use ss-2
  vpntype-server use vless-5
  vpntype-server auto
EOF
}

require_config() {
  [ -s "$CONFIG" ] || {
    echo "Missing config: $CONFIG" >&2
    exit 1
  }
}

list_tags() {
  require_config
  tags="$(sed -n 's/^[[:space:]]*"tag"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CONFIG" \
    | grep -E '^(vless|ss|wg|http|proxy)-[0-9A-Za-z_.-]+$|^vpntype-auto$' \
    | awk '!seen[$0]++')"
  if [ -s "$TAG_MAP" ]; then
    printf '%s\n' "$tags" | while read -r tag; do
      [ -n "$tag" ] || continue
      if [ "$tag" = "$AUTO_TAG" ]; then
        printf '%s\tauto\turltest\n' "$tag"
      else
        line="$(awk -F '\t' -v t="$tag" '$1 == t { print; exit }' "$TAG_MAP")"
        if [ -n "$line" ]; then
          printf '%s\n' "$line"
        else
          printf '%s\n' "$tag"
        fi
      fi
    done
  else
    printf '%s\n' "$tags"
  fi
}

list_tag_names_only() {
  require_config
  sed -n 's/^[[:space:]]*"tag"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CONFIG" \
    | grep -E '^(vless|ss|wg|http|proxy)-[0-9A-Za-z_.-]+$|^vpntype-auto$' \
    | awk '!seen[$0]++'
}

current_tag() {
  require_config
  sed -n 's/^[[:space:]]*"final"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CONFIG" | tail -1
}

native_wireguard_status() {
  command -v wg >/dev/null 2>&1 || return 1
  wg show vpntype >/dev/null 2>&1 || return 1

  echo "current=wg-kz"
  echo "mode=native-wireguard"
  echo "running"
  wg show vpntype | sed \
    -e 's/^\([[:space:]]*public key: \).*/\1(hidden)/' \
    -e 's/^\([[:space:]]*private key: \).*/\1(hidden)/' \
    -e 's/^\([[:space:]]*preshared key: \).*/\1(hidden)/'
}

remove_proxy_quic_block() {
  command -v nft >/dev/null 2>&1 || return 0
  nft -a list chain $PROXY_QUIC_TABLE "$PROXY_QUIC_CHAIN" 2>/dev/null \
    | awk '/oifname "vpntype" udp dport 443 reject/ { print $NF }' \
    | while read -r handle; do
      [ -n "$handle" ] || continue
      nft delete rule $PROXY_QUIC_TABLE "$PROXY_QUIC_CHAIN" handle "$handle" 2>/dev/null || true
    done
}

enable_proxy_quic_block() {
  command -v nft >/dev/null 2>&1 || return 0
  remove_proxy_quic_block
  nft insert rule $PROXY_QUIC_TABLE "$PROXY_QUIC_CHAIN" oifname "vpntype" udp dport 443 reject 2>/dev/null || true
  command -v conntrack >/dev/null 2>&1 && conntrack -D -p udp --dport 443 >/dev/null 2>&1 || true
}

sync_proxy_quic_block() {
  tag="$1"
  if [ "$tag" = "$PROXY_QUIC_TAG" ]; then
    enable_proxy_quic_block
  else
    remove_proxy_quic_block
  fi
}

schedule_proxy_quic_block() {
  (
    sleep 8
    [ "$(current_tag)" = "$PROXY_QUIC_TAG" ] || exit 0
    enable_proxy_quic_block
  ) >/dev/null 2>&1 &
}

set_final() {
  tag="$1"
  if ! list_tag_names_only | grep -qx "$tag"; then
    echo "Unknown tag: $tag" >&2
    echo "Available tags:" >&2
    list_tag_names_only >&2
    exit 2
  fi

  backup="$CONFIG.bak-server-$(date +%Y%m%d-%H%M%S)"
  cp "$CONFIG" "$backup"

  sed -i 's/^\([[:space:]]*"final"[[:space:]]*:[[:space:]]*"\)[^"]*\(".*\)$/\1'"$tag"'\2/' "$CONFIG"

  if ! sing-box check -c "$CONFIG"; then
    cp "$backup" "$CONFIG"
    echo "sing-box check failed; restored $backup" >&2
    exit 1
  fi

  "$SERVICE" restart
  sleep 3
  sync_proxy_quic_block "$tag"
  [ "$tag" = "$PROXY_QUIC_TAG" ] && schedule_proxy_quic_block
  echo "vpntype final outbound: $tag"
  echo "backup: $backup"
}

cmd="$(printf '%s' "${1:-list}" | tr -d '\r')"
case "$cmd" in
  list|servers)
    list_tags
    ;;
  status)
    if native_wireguard_status; then
      :
    else
      echo "current=$(current_tag)"
      "$SERVICE" status 2>/dev/null || true
    fi
    ;;
  auto)
    set_final "$AUTO_TAG"
    ;;
  use)
    tag="${2:-}"
    [ -n "$tag" ] || { usage; exit 2; }
    set_final "$tag"
    ;;
  *)
    usage
    exit 2
    ;;
esac
