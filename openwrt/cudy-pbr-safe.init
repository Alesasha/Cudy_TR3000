#!/bin/sh /etc/rc.common

START=99
STOP=8
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/cudy-pbr-safe-restart --boot
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    /usr/bin/cudy-pbr-safe-restart stop >/dev/null 2>&1 || true
}
