#!/bin/sh
set -eu

TARGET_TABLE="${TARGET_TABLE:-inet fw4}"
PBR_SCRIPT="${PBR_SCRIPT:-/usr/share/pbr/pbr.user.opencck-merged-vpn}"
OVERRIDE_DIR="${OVERRIDE_DIR:-/etc/pbr-overrides}"
VPN_BASE="${VPN_BASE:-/tmp/pbr_vpn_downloaded.clean}"
WAN_BASE="${WAN_BASE:-/tmp/pbr_wan_ru.clean}"
LAN_SUBNETS="${LAN_SUBNETS:-192.168.8.0/24 10.77.0.0/24}"
URL_CACHE_DIR="${URL_CACHE_DIR:-/tmp/cudy-pbr-url-cache}"
URL_CACHE_TTL="${URL_CACHE_TTL:-21600}"
STATE_DIR="${STATE_DIR:-/var/lib/cudy-router-agent/fast-state}"

work="/tmp/cudy-pbr-fast.$$"
batch="$work/apply.nft"
mkdir -p "$work" "$URL_CACHE_DIR" "$STATE_DIR"
trap 'rm -rf "$work"' EXIT INT TERM

collapse_file() {
  file="$1"
  [ -s "$file" ] || return 0
  [ -x /usr/bin/cudy-cidr-collapse ] || {
    echo "Missing /usr/bin/cudy-cidr-collapse" >&2
    exit 1
  }
  /usr/bin/cudy-cidr-collapse < "$file" > "$file.collapsed"
  mv "$file.collapsed" "$file"
}

target_interface="$(sed -n "s/^TARGET_INTERFACE='\([^']*\)'.*/\1/p" "$PBR_SCRIPT" | tail -1)"
case "$target_interface" in
  ''|*[!A-Za-z0-9_.-]*) echo "Invalid PBR target interface: $target_interface" >&2; exit 1 ;;
esac
[ -s "$VPN_BASE" ] || { echo "Missing cached VPN base: $VPN_BASE" >&2; exit 1; }
[ -s "$WAN_BASE" ] || { echo "Missing cached WAN base: $WAN_BASE" >&2; exit 1; }

clean_ipv4_list() {
  file="$1"
  [ -s "$file" ] || return 0
  awk '
  {
    sub(/#.*/, "")
    gsub(/\r/, "")
    gsub(/[[:space:]]/, "")
    if ($0 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/) print $0 "/32"
    else if ($0 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\/[0-9]+$/) print $0
  }' "$file"
}

clean_lines() {
  file="$1"
  [ -s "$file" ] || return 0
  awk '{ sub(/#.*/, ""); gsub(/\r/, ""); gsub(/^[[:space:]]+|[[:space:]]+$/, ""); if ($0 != "") print }' "$file"
}

resolve_domains() {
  file="$1"
  [ -s "$file" ] || return 0
  list="$work/domains.$(basename "$file")"
  output_dir="$list.out"
  mkdir -p "$output_dir"
  clean_lines "$file" > "$list"
  index=0
  while read -r domain; do
    index=$((index + 1))
    (
      nslookup "$domain" 2>/dev/null \
        | awk '/^Address: / { print $2 }' \
        | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' \
        | awk '{ print $1 "/32" }' > "$output_dir/$index" || true
    ) &
  done < "$list"
  wait
  cat "$output_dir"/* 2>/dev/null || true
}

fetch_url_lists() {
  file="$1"
  [ -s "$file" ] || return 0
  clean_lines "$file" | while read -r url; do
    key="$(printf '%s' "$url" | sha256sum | awk '{ print $1 }')"
    cache="$URL_CACHE_DIR/$key.clean"
    now="$(date +%s)"
    modified="$(stat -c %Y "$cache" 2>/dev/null || echo 0)"
    if [ -s "$cache" ] && [ $((now - modified)) -lt "$URL_CACHE_TTL" ]; then
      cat "$cache"
      continue
    fi
    tmp="$work/url.$key.raw"
    if uclient-fetch --no-check-certificate -qO "$tmp" "$url"; then
      clean_ipv4_list "$tmp" | sort -u > "$cache.tmp"
      mv "$cache.tmp" "$cache"
      cat "$cache"
    else
      logger -t cudy-pbr-fast "override source download failed: $url"
      [ ! -s "$cache" ] || cat "$cache"
    fi
    rm -f "$tmp"
  done
}

build_override() {
  iface="$1"
  output="$2"
  {
    clean_ipv4_list "$OVERRIDE_DIR/force-$iface.ips"
    resolve_domains "$OVERRIDE_DIR/force-$iface.domains"
    fetch_url_lists "$OVERRIDE_DIR/force-$iface.urls"
  } | sort -u > "$output"
  collapse_file "$output"
}

extract_managed() {
  file="$1"
  [ -s "$file" ] || return 0
  awk '
    /^# BEGIN cudy-router-agent$/ { active=1; next }
    /^# END cudy-router-agent$/ { active=0; next }
    active { print }
  ' "$file"
}

build_managed_override() {
  iface="$1"
  output="$2"
  ip_file="$work/managed-$iface.ips"
  domain_file="$work/managed-$iface.domains"
  url_file="$work/managed-$iface.urls"
  extract_managed "$OVERRIDE_DIR/force-$iface.ips" > "$ip_file"
  extract_managed "$OVERRIDE_DIR/force-$iface.domains" > "$domain_file"
  extract_managed "$OVERRIDE_DIR/force-$iface.urls" > "$url_file"
  {
    clean_ipv4_list "$ip_file"
    resolve_domains "$domain_file"
    fetch_url_lists "$url_file"
  } | sort -u > "$output"
  collapse_file "$output"
}

append_elements() {
  set_name="$1"
  file="$2"
  n=0
  params=""
  while read -r value; do
    [ -n "$value" ] || continue
    params="${params:+$params, }$value"
    n=$((n + 1))
    if [ "$n" -ge 200 ]; then
      echo "add element $TARGET_TABLE $set_name { $params }" >> "$batch"
      n=0
      params=""
    fi
  done < "$file"
  [ -z "$params" ] || echo "add element $TARGET_TABLE $set_name { $params }" >> "$batch"
}

register_set() {
  iface="$1"
  file="$2"
  set_name="pbr_${iface}_4_dst_ip_user"
  nft list set $TARGET_TABLE "$set_name" >/dev/null 2>&1 || {
    echo "PBR nft set is missing for $iface: $set_name" >&2
    exit 1
  }
  echo "flush set $TARGET_TABLE $set_name" >> "$batch"
  append_elements "$set_name" "$file"
}

interface_names() {
  for file in "$OVERRIDE_DIR"/force-*.domains "$OVERRIDE_DIR"/force-*.ips "$OVERRIDE_DIR"/force-*.urls; do
    [ -e "$file" ] || continue
    name="${file##*/}"
    iface="${name#force-}"
    iface="${iface%.*}"
    case "$iface" in ''|*[!A-Za-z0-9_.-]*) continue ;; esac
    printf '%s\n' "$iface"
  done | sort -u
}

for iface in $(interface_names); do
  case "$iface" in
    wan|vpn|awg2|"$target_interface")
      build_managed_override "$iface" "$work/managed-$iface.clean"
      ;;
    *)
      build_override "$iface" "$work/force-$iface.clean"
      ;;
  esac
done

for special in wan vpn awg2 "$target_interface"; do
  [ -e "$work/managed-$special.clean" ] || build_managed_override "$special" "$work/managed-$special.clean"
done

grep -vxF -f "$WAN_BASE" "$work/managed-wan.clean" > "$work/special-wan.clean" || true
collapse_file "$work/special-wan.clean"

target_managed="$work/special-target.clean"
{
  cat "$work/managed-vpn.clean"
  [ "$target_interface" = "vpn" ] || cat "$work/managed-$target_interface.clean"
  if [ "$target_interface" = "awg2" ]; then
    cat "$work/managed-awg2.clean"
  fi
} | sort -u | grep -vxF -f "$VPN_BASE" > "$target_managed" || true
collapse_file "$target_managed"

# Rebuild special sets from their complete base plus managed additions. Exact
# line deltas are unsafe for nft interval sets: a newly added /32 may already
# be covered by an existing broader CIDR and causes "interval overlaps".
full_wan="$work/full-wan.clean"
{
  cat "$WAN_BASE"
  cat "$work/special-wan.clean"
} | sort -u > "$full_wan"
collapse_file "$full_wan"

full_target="$work/full-target.clean"
{
  cat "$VPN_BASE"
  cat "$target_managed"
} | sort -u > "$full_target"
collapse_file "$full_target"

sync_special_state() {
  cp "$work/special-wan.clean" "$STATE_DIR/pbr_wan_4_dst_ip_user.clean"
  cp "$target_managed" "$STATE_DIR/pbr_${target_interface}_4_dst_ip_user.clean"
  if [ "$target_interface" != "awg2" ]; then
    cp "$work/managed-awg2.clean" "$STATE_DIR/pbr_awg2_4_dst_ip_user.clean"
  fi
}

if [ "${CUDY_PBR_STATE_SYNC:-0}" = "1" ]; then
  sync_special_state
  echo "Cudy PBR fast state synchronized; target=$target_interface"
  exit 0
fi

: > "$batch"
register_set wan "$full_wan"
register_set "$target_interface" "$full_target"

if [ "$target_interface" != "awg2" ]; then
  register_set awg2 "$work/managed-awg2.clean"
fi

for iface in $(interface_names); do
  case "$iface" in wan|vpn|awg2|"$target_interface") continue ;; esac
  register_set "$iface" "$work/force-$iface.clean"
done

if [ "${CUDY_PBR_DRY_RUN:-0}" = "1" ]; then
  nft -c -f "$batch"
  cp "$batch" /tmp/cudy-pbr-fast-apply.preview.nft
  echo "Cudy PBR fast apply validation passed; batch=/tmp/cudy-pbr-fast-apply.preview.nft"
  exit 0
fi

nft -f "$batch"
for iface in $(interface_names); do
  case "$iface" in wan|vpn|awg2|"$target_interface") continue ;; esac
  cp "$work/force-$iface.clean" "/tmp/pbr_force_${iface}.clean"
done
sync_special_state

if command -v conntrack >/dev/null 2>&1; then
  for subnet in $LAN_SUBNETS; do
    conntrack -D -s "$subnet" >/dev/null 2>&1 || true
  done
fi

logger -t cudy-pbr-fast "applied override sets atomically; target=$target_interface"
echo "Cudy PBR overrides applied atomically; target=$target_interface"
