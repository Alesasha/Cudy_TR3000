#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/cudy-fallback \
        -listen 127.0.0.1:8765 \
        -public-dir /www/cudy-control \
        -max-state-age 3h
    procd_set_param respawn 30 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
