#!/bin/sh

# Serialize expensive PBR rebuilds and always fail open to the normal WAN.
set -u

LOCK_DIR="${LOCK_DIR:-/tmp/cudy-pbr-safe.lock}"
STATE_DIR="${STATE_DIR:-/var/run/cudy-pbr-safety}"
START_TIMEOUT="${START_TIMEOUT:-240}"
READY_TIMEOUT="${READY_TIMEOUT:-15}"
BOOT_DELAY="${BOOT_DELAY:-45}"
TAG="cudy-pbr-safe"

log() {
    logger -t "$TAG" "$*"
    printf '%s\n' "$*"
}

set_forwarding() {
    echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || true
    if [ -e /proc/sys/net/ipv6/conf/all/forwarding ]; then
        echo 1 > /proc/sys/net/ipv6/conf/all/forwarding 2>/dev/null || true
    fi
}

run_with_timeout() {
    if command -v timeout >/dev/null 2>&1; then
        timeout "$START_TIMEOUT" "$@"
    else
        "$@"
    fi
}

pbr_dataplane_ready() {
    ip -4 rule show 2>/dev/null | grep -Eq 'fwmark .* lookup pbr_' || return 1
    nft list chain inet fw4 pbr_prerouting 2>/dev/null | grep -q 'goto pbr_mark_' || return 1
}

wait_for_dataplane() {
    elapsed=0
    while [ "$elapsed" -lt "$READY_TIMEOUT" ]; do
        if pbr_dataplane_ready; then
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
    return 1
}

fail_open() {
    reason="$1"
    log "PBR failed; restoring direct WAN: $reason"
    run_with_timeout /etc/init.d/pbr stop >/tmp/cudy-pbr-stop.log 2>&1 || true
    rm -f /var/run/pbr.lock
    set_forwarding
    rm -f "$STATE_DIR/starting" "$STATE_DIR/expected"
    printf '%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$reason" > "$STATE_DIR/failed"
    return 1
}

cleanup() {
    rm -f "$STATE_DIR/starting"
    rm -f "$LOCK_DIR/pid"
    rmdir "$LOCK_DIR" 2>/dev/null || true
}

mkdir -p "$STATE_DIR"
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    owner_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
    case "$owner_pid" in
        ''|*[!0-9]*) owner_pid=0 ;;
    esac
    if [ "$owner_pid" -gt 1 ] && kill -0 "$owner_pid" 2>/dev/null; then
        log "another PBR transaction is already running; request coalesced"
        exit 0
    fi
    log "removing stale PBR transaction lock"
    rm -f "$LOCK_DIR/pid"
    rmdir "$LOCK_DIR" 2>/dev/null || true
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        log "could not acquire PBR transaction lock"
        exit 1
    fi
fi
printf '%s\n' "$$" > "$LOCK_DIR/pid"
trap cleanup EXIT INT TERM

case "${1:-restart}" in
    --boot)
        delay="$(uci -q get cudy-pbr-safety.main.boot_delay 2>/dev/null || echo "$BOOT_DELAY")"
        case "$delay" in ''|*[!0-9]*) delay="$BOOT_DELAY" ;; esac
        log "waiting ${delay}s for network and tunnel interfaces to settle"
        sleep "$delay"
        ;;
    restart|start|'') ;;
    stop)
        rm -f "$STATE_DIR/expected" "$STATE_DIR/failed"
        run_with_timeout /etc/init.d/pbr stop || true
        rm -f /var/run/pbr.lock
        set_forwarding
        log "PBR stopped; direct WAN remains active"
        exit 0
        ;;
    *)
        echo "Usage: $0 [--boot|restart|start|stop]" >&2
        exit 2
        ;;
esac

printf '%s\n' "$(date +%s)" > "$STATE_DIR/starting"
rm -f "$STATE_DIR/failed" "$STATE_DIR/expected"
set_forwarding

run_with_timeout /etc/init.d/pbr stop >/tmp/cudy-pbr-stop.log 2>&1 || true
set_forwarding

# pbr may have left an invalid generated include behind after an interrupted
# update. Stop removes that include; validate the fail-open base firewall only
# after cleanup so stale PBR data cannot prevent recovery.
if ! fw4 check >/tmp/cudy-pbr-fw4-check.log 2>&1; then
    fail_open "fw4 validation failed after PBR stop"
    exit $?
fi

log "starting one serialized PBR rebuild"
if ! run_with_timeout /etc/init.d/pbr start >/tmp/cudy-pbr-start.log 2>&1; then
    fail_open "pbr start command failed or timed out"
    exit $?
fi
set_forwarding

if ! wait_for_dataplane; then
    fail_open "pbr dataplane did not become ready"
    exit $?
fi
if ! fw4 check >/tmp/cudy-pbr-fw4-check.log 2>&1; then
    fail_open "fw4 validation failed after PBR start"
    exit $?
fi
if ! nft list table inet fw4 2>/dev/null | grep -q 'pbr_'; then
    fail_open "PBR nft objects are absent"
    exit $?
fi

# The package occasionally leaves its empty command lock behind even though
# start has returned and the dataplane is ready. Removing it here cannot race
# a PBR command: this wrapper serializes rebuilds and the start command above
# has already exited.
rm -f /var/run/pbr.lock

touch "$STATE_DIR/expected"
rm -f "$STATE_DIR/failed"
# BusyBox ash normally runs the EXIT trap, but explicitly clear the in-progress
# marker before reporting success so the independent watchdog can never mistake
# a completed rebuild for a stale one.
cleanup
log "PBR rebuild completed; forwarding is enabled"
exit 0
