#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

start_service() {
  procd_open_instance
  procd_set_param command /bin/sh -c '
    for i in $(seq 1 30); do
      ip rule show 2>/dev/null | grep -q "lookup pbr_" && break
      sleep 2
    done
    [ -x /usr/bin/cudy-user-routes-apply ] && /usr/bin/cudy-user-routes-apply || true
  '
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}
