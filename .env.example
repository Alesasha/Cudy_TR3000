# Local operator secrets. Copy to .env locally; do not commit real values.

# Cudy router SSH.
CUDY_SSH_PASSWORD=

# AmneziaWG server SSH passwords used by tools/awg_client_add.py.
AWG_SSH_PASSWORD_CUDY_HOME=
AWG_SSH_PASSWORD_HOSTVDS_USWEST=
AWG_SSH_PASSWORD_MEGAHOST_AKTAU=

# VPNtype proxy API credentials for openwrt/update-vpntype-proxy-runtime.sh.
VPNTYPE_AUTH_DEFAULT=
VPNTYPE_UUID_DEFAULT=

# LokVPN subscription URL for openwrt/lokvpn-refresh.
SUB_URL=
