<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not configured"
            android:textSize="18sp" />
        <TextView
            android:id="@+id/serviceStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:text="Service: -"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/policyStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="Policy: -"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/probeStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="Probe: -"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/routeStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="Routes: -"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/transportStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="Transports: -"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/engineStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="Engine: -"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/permissionStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:text="Permissions: -"
            android:textSize="14sp" />
        <EditText
            android:id="@+id/controlUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Control URL"
            android:inputType="textUri" />
        <EditText
            android:id="@+id/deviceIdInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device ID"
            android:inputType="text" />
        <EditText
            android:id="@+id/tokenInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device token"
            android:inputType="textPassword" />
        <EditText
            android:id="@+id/sshHostInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SSH host"
            android:inputType="textUri" />
        <EditText
            android:id="@+id/sshUserInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SSH user"
            android:inputType="text" />
        <EditText
            android:id="@+id/sshKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:hint="SSH private key"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="4" />
        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save" />
        <Button
            android:id="@+id/setupPermissionsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setup permissions" />
        <Button
            android:id="@+id/fetchButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fetch policy" />
        <Button
            android:id="@+id/checkButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check control" />
        <Button
            android:id="@+id/prepareButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prepare VPN" />
        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start agent" />
        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop agent" />
        <TextView
            android:id="@+id/outputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:textIsSelectable="true"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
