$env:VPN_CONTROL_URL = "http://127.0.0.1:8765"
# Optional failover URLs. The primary VPN_CONTROL_URL is still tried first.
# Example: use local SSH tunnel first, then Cudy fallback reachable through VPN/LAN.
$env:VPN_CONTROL_URLS = "http://10.77.0.1:8765,http://192.168.8.1:8765"
# Optional discovery manifests. These can be static files on Cudy that tell the
# agent the new primary after uswest is rebuilt or moved.
$env:VPN_CONTROL_ENDPOINT_MANIFEST_URLS = "http://10.77.0.1/cudy-control/endpoints.json,http://192.168.8.1/cudy-control/endpoints.json"
$env:VPN_CONTROL_PRIMARY_SSH_HOST = "95.182.91.203"
$env:VPN_CONTROL_PRIMARY_SSH_USER = "cudy-tunnel-windows"
# $env:VPN_CONTROL_PRIMARY_SSH_KEY = "$PSScriptRoot\uswest_control_tunnel_ed25519"
$env:VPN_AGENT_TOKEN = "vca_replace_me"
$env:VPN_AGENT_DEVICE_ID = "replace-me-windows"

# Optional: needed only for -VpnTypeTransport proxyde=proxyde, proxyru=proxyru, etc.
$env:VPNTYPE_AUTH_DEFAULT = ""
$env:VPNTYPE_UUID_DEFAULT = ""

# Optional: needed only for -LokVpnTransport de1=lokvpn-de1, fr2=lokvpn-fr2, etc.
$env:LOKVPN_SUB_URL = ""
