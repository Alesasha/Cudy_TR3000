$env:VPN_CONTROL_URL = "http://127.0.0.1:8765"
$env:VPN_AGENT_TOKEN = "vca_replace_me"
$env:VPN_AGENT_DEVICE_ID = "replace-me-windows"

# Optional: needed only for -VpnTypeTransport proxyde=proxyde, proxyru=proxyru, etc.
$env:VPNTYPE_AUTH_DEFAULT = ""
$env:VPNTYPE_UUID_DEFAULT = ""

# Optional: needed only for -LokVpnTransport de1=lokvpn-de1, fr2=lokvpn-fr2, etc.
$env:LOKVPN_SUB_URL = ""
